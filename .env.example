BOT_TOKEN=your_telegram_bot_token_here

BACKEND_BASE_URL=http://localhost:5000

# ============================================================================
# TRANSAK — STAGING (usare per sviluppo e test)
# ============================================================================
# TRANSAK_API_KEY=your_staging_api_key_here
# TRANSAK_API_SECRET=your_staging_api_secret_here
# TRANSAK_REFRESH_TOKEN_URL=https://staging-api.transak.com/api/v2/partner/token
# TRANSAK_CREATE_WIDGET_URL=https://staging-api.transak.com/api/v2/partner/widget-url

# ============================================================================
# TRANSAK — PRODUCTION (usare solo in ambiente di produzione)
# ============================================================================
# TRANSAK_API_KEY=your_production_api_key_here
# TRANSAK_API_SECRET=your_production_api_secret_here
# TRANSAK_REFRESH_TOKEN_URL=https://api.transak.com/api/v2/partner/token
# TRANSAK_CREATE_WIDGET_URL=https://api.transak.com/api/v2/partner/widget-url

# ============================================================================
# ATTENZIONE: NON mischiare chiavi staging con endpoint production e viceversa.
# Un mismatch causa errori 401 Unauthorized da Transak.
# Scegliere UNA sezione (staging o production) e commentare l'altra.
# ============================================================================

# Per usare STAGING: decommenta le 4 righe della sezione STAGING sopra.
# Per usare PRODUCTION: decommenta le 4 righe della sezione PRODUCTION sopra.
# Ricorda di impostare TRANSAK_API_KEY e TRANSAK_API_SECRET con le credenziali
# dello stesso ambiente scelto.

TREASURY_WALLET=0x57f333c398c9625D84432aBD00871E2d8049cAaC

REFERRER_DOMAIN=https://frontemeridionale.github.io

PORT=5000

LOG_LEVEL=INFO

BACKEND_REQUEST_TIMEOUT=60

DEBOUNCE_WINDOW_SECONDS=5

WIDGET_URL_RATE_LIMIT_PER_MINUTE=10

WIDGET_URL_CACHE_TTL_SECONDS=300

TRANSAK_RETRY_ON_429_ATTEMPTS=2

TRANSAK_RETRY_ON_429_BASE_WAIT=1.0

TRANSAK_RETRY_ON_429_MAX_WAIT=30

TOKEN_CACHE_DEFAULT_TTL=518400
