BOT_TOKEN=your_telegram_bot_token_here

BACKEND_BASE_URL=http://localhost:5000

TRANSAK_API_KEY=your_transak_api_key_here
TRANSAK_API_SECRET=your_transak_api_secret_here

TRANSAK_REFRESH_TOKEN_URL=https://staging-api.transak.com/api/v2/partner/token
TRANSAK_CREATE_WIDGET_URL=https://staging-api.transak.com/api/v2/partner/widget-url

TREASURY_WALLET=0x57f333c398c9625D84432aBD00871E2d8049cAaC

REFERRER_DOMAIN=https://frontemeridionale.github.io

PORT=5000

LOG_LEVEL=INFO

BACKEND_REQUEST_TIMEOUT=60

DEBOUNCE_WINDOW_SECONDS=5

WIDGET_URL_RATE_LIMIT_PER_MINUTE=10

WIDGET_URL_CACHE_TTL_SECONDS=300

TRANSAK_RETRY_ON_429_ATTEMPTS=2

TRANSAK_RETRY_ON_429_BASE_WAIT=1.0

TRANSAK_RETRY_ON_429_MAX_WAIT=30

TOKEN_CACHE_DEFAULT_TTL=518400

RATE_LIMIT_TRACKER_MAX_ENTRIES=10000

WIDGET_CACHE_MAX_ENTRIES=1000

# ============================================================================
# IMPORTANT: TRANSAK STAGING vs PRODUCTION
# ============================================================================
# The TRANSAK_REFRESH_TOKEN_URL and TRANSAK_CREATE_WIDGET_URL variables above
# are pointing to Transak's STAGING environment (staging-api.transak.com).
#
# In production deployment, these MUST be replaced with the actual production
# endpoints:
# TRANSAK_REFRESH_TOKEN_URL=https://api.transak.com/api/v2/partner/token
# TRANSAK_CREATE_WIDGET_URL=https://api.transak.com/api/v2/partner/widget-url
#
# Also ensure that TRANSAK_API_KEY and TRANSAK_API_SECRET are replaced with
# valid production credentials from Transak.
